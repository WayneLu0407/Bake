@model Bake.Areas.Seller.ViewModels.DashboardViewModel

<body>
    <main class="main-wrapper" style="margin-left: 0; padding-left: 0;">
        <!-- ========== Analytics Dashboard start ========== -->
        <section class="section">
            <div class="container-fluid">
                <!-- ========== title-wrapper start ========== -->
                <div class="title-wrapper pt-30">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <div class="title">
                                <h2>營運總覽</h2>
                            </div>
                        </div>
                        <!-- end col -->
                        <div class="col-md-6">
                            <div class="breadcrumb-wrapper">
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb">
                                        <li class="breadcrumb-item">
                                            <a href="#0">Dashboard</a>
                                        </li>
                                        <li class="breadcrumb-item active" aria-current="page">
                                            Analytics
                                        </li>
                                    </ol>
                                </nav>
                            </div>
                        </div>
                        <!-- end col -->
                    </div>
                    <!-- end row -->
                </div>
                <!-- ========== 卡片:今日營收、待出貨訂單、本月總訂單數、低庫存警示* ========== -->
                <div class="row">
                    <!-- 今日營收 -->
                    <div class="col">
                        <div class="icon-card mb-30">
                            <div class="icon purple">
                                <i class="lni lni-users"></i>
                            </div>
                            <div class="content">
                                <h6 class="mb-10">今日營收</h6>
                                <h3 class="text-bold mb-10">@Model.TodayRevenue</h3>
                                <p class="text-sm text-success">
                                    <i class="lni lni-arrow-up"></i> +23.4%
                                </p>
                            </div>
                        </div>
                        <!-- End Icon Cart -->
                    </div>
                    <!-- 本月總營收 -->
                    <div class="col">
                        <div class="icon-card mb-30">
                            <div class="icon orange">
                                <i class="lni lni-pie-chart"></i>
                            </div>
                            <div class="content">
                                <h6 class="mb-10">本月總營收</h6>
                                <h3 class="text-bold mb-10">@Model.MonthRevenue</h3>
                                <p class="text-sm text-success">
                                    <i class="lni lni-arrow-up"></i> +23.4%
                                </p>
                            </div>
                        </div>
                    </div>
                    <!-- 待出貨訂單 -->
                    <div class="col">
                        <div class="icon-card mb-30">
                            <div class="icon success">
                                <i class="lni lni-eye"></i>
                            </div>
                            <div class="content">
                                <h6 class="mb-10">待出貨訂單</h6>
                                <h3 class="text-bold mb-10">@Model.PendingOrdersCount</h3>
                                <p class="text-sm text-danger">
                                    <i class="lni lni-arrow-down"></i> -12.00%
                                </p>
                            </div>
                        </div>
                    </div>
                    <!-- 本月總訂單數 -->
                    <div class="col">
                        <div class="icon-card mb-30">
                            <div class="icon orange">
                                <i class="lni lni-pie-chart"></i>
                            </div>
                            <div class="content">
                                <h6 class="mb-10">本月總訂單數</h6>
                                <h3 class="text-bold mb-10">@Model.TotalOrdersMonth</h3>
                                <p class="text-sm text-success">
                                    <i class="lni lni-arrow-up"></i> +23.4%
                                </p>
                            </div>
                        </div>
                    </div>
                    <!-- 在架商品總數 -->
                    <div class="col">
                        <div class="icon-card mb-30">
                            <div class="icon primary">
                                <i class="lni lni-thumbs-up"></i>
                            </div>
                            <div class="content">
                                <h6 class="mb-10">在架商品總數</h6>
                                <h3 class="text-bold mb-10">@Model.TotalProductsCount</h3>
                                <p class="text-sm text-danger">
                                    <i class="lni lni-arrow-down"></i> -2.00%
                                </p>
                            </div>
                        </div>
                        <!-- End Icon Cart -->
                    </div>
                </div>
                <!-- 卡片資訊結束 -->
                <!-- 趨勢圖：顯示過去 7 天的訂單量變化。 -->
                <div class="row">
                    <div class="col-lg">
                        <div class="card-style mb-30">
                            <div class="title d-flex justify-content-between">
                                <div class="left">
                                    <h6 class="text-medium mb-20">過去 7 天訂單量變化</h6>
                                </div>
                            </div>
                            <!-- End Title -->
                            <div class="chart">
                                <canvas id="trendChart" style="width: 100%; height: 400px;"></canvas>
                            </div>
                            <!-- End Chart -->
                        </div>
                    </div>
                    <!-- End Col -->
                </div>
                <div class="row">
                    <!-- 圓餅圖：顯示不同類別產品的銷售佔比。 -->
                    <div class="col-lg-6">
                        <div class="card-style mb-30">
                            <div class="title d-flex justify-content-between">
                                <div class="left">
                                    <h6 class="text-medium mb-20">類別產品銷售佔比</h6>
                                </div>
                            </div>
                            <!-- End Title -->
                            <div class="chart max-w-350 mx-auto">
                                <canvas id="categoryChart" style="width: 100%; height: 350px"></canvas>
                            </div>
                        </div>
                    </div>
                    <!-- 低庫存警示 -->
                    <div class="col-lg-6">
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-white py-3 d-flex align-items-center">
                                <h6 class="m-0 font-weight-bold text-primary">
                                    <i class="fas fa-exclamation-triangle text-warning me-2"></i>低庫存警示 ⚠️
                                </h6>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-3">
                                        <thead class="table-light">
                                            <tr>
                                                <th class="ps-3">商品名稱</th>
                                                <th class="text-center">目前庫存</th>
                                                <th class="text-center">狀態</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model.LowStock != null && Model.LowStock.Any())
                                            {
                                                @foreach (var item in Model.LowStock)
                                                {
                                                    <tr>
                                                        <td class="ps-3 fw-bold">@item.LowPName</td>
                                                        <td class="text-center">
                                                            <span class="badge @(item.Stock <= 2 ? "bg-danger" : "bg-warning text-dark")">
                                                                @item.Stock
                                                            </span>
                                                        </td>
                                                        <td class="text-center">
                                                            <a href="#" class="btn btn-sm btn-outline-primary">補貨</a>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td colspan="3" class="text-center py-4 text-muted">
                                                        <i class="fas fa-check-circle text-success me-1"></i> 目前庫存充足
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <!-- 商品牆：列出目前賣最好的前幾名甜點。 -->
                <div class="row">
                    <div class="col-lg-12">
                        <div class="card-style mb-30">
                            <div class="title d-flex justify-content-between align-items-center mb-20">
                                <div class="left">
                                    <h6 class="text-medium">熱門商品排行 (Top 5)</h6>
                                </div>
                                <div class="right">
                                    <div class="select-style-1 mb-0">
                                        <div class="select-position">
                                            <select class="bg-transparent border-0 lni-text-size">
                                                <option value="">本月</option>
                                                <option value="">上月</option>
                                                <option value="">年度</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="table-responsive">
                                <table class="table top-selling-table">
                                    <thead>
                                        <tr>
                                            <th>排行</th>
                                            <th>商品</th>
                                            <th class="text-center">類別</th>
                                            <th class="text-center">銷量</th>
                                            <th class="text-center">累積營收</th>
                                            <th class="text-end">趨勢</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.TopProducts != null && Model.TopProducts.Any())
                                        {
                                            int rank = 1;
                                            foreach (var product in Model.TopProducts)
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="check-input-primary-light">
                                                            @if (rank <= 3)
                                                            {
                                                                <span class="badge rounded-pill bg-primary">No.@rank</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge rounded-pill bg-light text-dark">@rank</span>
                                                            }
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <div class="product d-flex align-items-center">
                                                            <div class="image me-3" style="width: 50px; height: 50px; overflow: hidden; border-radius: 8px;">
                                                                <img src="@product.ImageUrl" alt="@product.ProductName" style="width: 100%; height: 100%; object-fit: cover;" />
                                                            </div>
                                                            <p class="text-sm fw-bold">@product.ProductName</p>
                                                        </div>
                                                    </td>
                                                    <td class="text-center">
                                                        <p class="text-sm">@product.CategoryName</p>
                                                    </td>
                                                    <td class="text-center">
                                                        <p class="text-sm fw-bold">@product.TotalSales 件</p>
                                                    </td>
                                                    <td class="text-center">
                                                        <p class="text-sm text-success fw-bold">$@product.Revenue.ToString("N0")</p>
                                                    </td>
                                                    <td class="text-end">
                                                        <div class="action">
                                                            <button class="text-primary border-0 bg-transparent">
                                                                <i class="lni lni-stats-up"></i>
                                                            </button>
                                                        </div>
                                                    </td>
                                                </tr>
                                                rank++;
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="6" class="text-center py-4 text-muted">暫無銷售統計數據</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- End Row -->
            </div>
            <!-- end container -->
        </section>
        <!-- ========== section end ========== -->
        <!-- ========== Marketing Dashboard ========== -->
        <section class="marketingDashboard">
            <div class="container-fluid">
                <!-- ========== title-wrapper start ========== -->
                <div class="title-wrapper pt-30">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <div class="title">
                                <h2>Marketing Dashboard</h2>
                            </div>
                        </div>
                        <!-- end col -->
                        <div class="col-md-6">
                            <div class="breadcrumb-wrapper">
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb">
                                        <li class="breadcrumb-item">
                                            <a href="#0">Dashboard</a>
                                        </li>
                                        <li class="breadcrumb-item active" aria-current="page">
                                            Marketing
                                        </li>
                                    </ol>
                                </nav>
                            </div>
                        </div>
                        <!-- end col -->
                    </div>
                    <!-- end row -->
                </div>
                <!-- ========== title-wrapper end ========== -->
