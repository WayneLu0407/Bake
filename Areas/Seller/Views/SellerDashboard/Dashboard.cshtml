                                          fill="currentColor" />
                                </svg>
                            </div>
                            <div class="card-content">
                                <p class="mb-2 fw-medium">Instagram Followers</p>
                                <h3 class="text-bold mb-1">522K</h3>
                                <p class="d-flex align-items-center gap-2 fw-medium text-sm">
                                    <span class="d-inline-flex align-items-center gap-2 text-danger-2">
                                        <i class="lni lni-arrow-top-right"></i>
                                        -1.5%
                                    </span>
                                    <span class="text-gray">than last Week</span>
                                </p>
                            </div>
                        </div>
                        <!-- End Icon Cart -->
                    </div>
                    <!-- End Col -->
                    <div class="col-lg-4 col-sm-6">
                        <div class="icon-card icon-card-4 mb-30">
                            <div class="icon orange">
                                <svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M13.0941 23.8333C12.7473 23.8333 12.4604 23.6969 12.2337 23.4241C12.0068 23.1664 11.8935 22.8482 11.8935 22.4692V20.6049L12.4338 21.1506C11.5133 21.1202 10.7129 20.9914 10.0326 20.764C9.35224 20.5368 8.7853 20.2866 8.33174 20.0138C8.03827 19.8471 7.8315 19.6197 7.71143 19.3318C7.60472 19.0438 7.5647 18.7483 7.59138 18.4451C7.61806 18.1268 7.71143 17.854 7.87152 17.6266C8.03159 17.3841 8.23837 17.225 8.49182 17.1492C8.75862 17.0734 9.05877 17.134 9.39226 17.3311C9.71242 17.5281 10.1593 17.7328 10.7329 17.9449C11.3066 18.1419 12.0068 18.2405 12.834 18.2405C13.4476 18.2405 13.9411 18.1647 14.3147 18.0131C14.6882 17.8464 14.955 17.6342 15.115 17.3766C15.2885 17.1188 15.3752 16.8233 15.3752 16.4899C15.3752 16.2171 15.3152 15.9745 15.1951 15.7623C15.0884 15.5502 14.895 15.3683 14.6149 15.2167C14.348 15.05 13.9878 14.9136 13.5343 14.8074L11.3332 14.2618C10.1059 13.9586 9.19217 13.4433 8.59187 12.7158C7.99157 11.9731 7.69143 11.0183 7.69143 9.85117C7.69143 8.94177 7.88485 8.13087 8.27171 7.41851C8.67191 6.70614 9.21885 6.13017 9.91252 5.69063C10.6195 5.25108 11.4466 4.98584 12.3937 4.89489L11.8935 5.25866V3.53078C11.8935 3.15186 12.0068 2.83357 12.2337 2.5759C12.4604 2.30308 12.7473 2.16667 13.0941 2.16667C13.4276 2.16667 13.7077 2.30308 13.9345 2.5759C14.1613 2.83357 14.2747 3.15186 14.2747 3.53078V5.25866L13.7744 4.84942C14.3214 4.87974 14.9083 5.00099 15.5353 5.21319C16.1756 5.41022 16.7292 5.6982 17.1961 6.07712C17.4496 6.259 17.6229 6.48636 17.7163 6.75918C17.823 7.032 17.8498 7.30483 17.7964 7.57765C17.7564 7.85047 17.6563 8.09298 17.4963 8.30518C17.3362 8.50222 17.1228 8.63105 16.8559 8.69167C16.6024 8.73715 16.3024 8.66136 15.9555 8.46432C15.5953 8.26729 15.2018 8.10056 14.7749 7.96415C14.348 7.82773 13.8211 7.75953 13.1942 7.75953C12.4071 7.75953 11.7934 7.94142 11.3533 8.30518C10.9263 8.66894 10.7129 9.13881 10.7129 9.71476C10.7129 10.1392 10.8397 10.4802 11.093 10.7379C11.3599 10.9955 11.8201 11.2077 12.4738 11.3745L14.6949 11.92C15.9622 12.2384 16.8959 12.7537 17.4963 13.4661C18.1099 14.1785 18.4167 15.103 18.4167 16.2398C18.4167 17.134 18.2233 17.9297 17.8365 18.6269C17.4496 19.309 16.916 19.8623 16.2356 20.2866C15.5553 20.7111 14.7615 20.9838 13.8545 21.1051L14.2747 20.5821V22.4692C14.2747 22.8482 14.1613 23.1664 13.9345 23.4241C13.7211 23.6969 13.441 23.8333 13.0941 23.8333Z"
                                          fill="currentColor" />
