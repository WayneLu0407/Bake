                            </div>
                        </div>
                        <!-- End Icon Cart -->
                    </div>
                    <!-- End Col -->
                </div>
                <!-- End Row -->
               
            </div>
            <!-- End Row -->
        </div>
        <!-- end -->
    </section>
    <!-- ========== Marketing Dashboard end ========== -->
</main>
<!-- ======== main-wrapper end =========== -->
</body>



@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const categoryColors = [
        '#624BFF', // 經典靛藍
        '#FB7D5B', // 活力珊瑚橘
        '#2E91FF', // 天空藍
        '#F151B1', // 浪漫野莓粉
        '#1CCAB8', // 清新薄荷綠
        '#8D6E63', // 溫潤可可棕
        '#FFBE46', // 蜂蜜金黃
        '#A155B9', // 優雅薰衣草紫
        '#757575'  // 中性質感灰
        ];
        //趨勢圖
        new Chart( document.getElementById("trendChart"),{
            type:'line',
            data:{
                labels:@Html.Raw(Json.Serialize(Model.Last7DaysLabels)),
                datasets:[{
                    label:'日訂單量',
                    data: @Json.Serialize(Model.Last7DaysData),
                    backgroundColor: "transparent",
                    borderColor: '#FAA916',
                    borderWidth: 8,
                    tension:0.3,
                    pointHoverBorderWidth: 3,
                    fill: true,
                    pointRadius: 8,
                    pointBackgroundColor: "transparent",
                    pointHoverBackgroundColor: "#FAA916",
                    pointBorderColor: "transparent",
                    pointHoverBorderColor: "#fff",
                    pointHoverRadius: 8,
                    cubicInterpolationMode: "monotone", // Add this line for curved line
                }],
            },
            options: {
                responsive: true,
                    plugins: {
                        legend: {
                        display: false // 隱藏上方的標籤文字，讓畫面更乾淨
                        }
                    },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                        stepSize: 1 // 確保垂直軸顯示的是整數訂單數
                        }
                    }
                }
            }
          });

        new Chart(document.getElementById('categoryChart'), {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.CategoryLabels)),
                datasets: [{
                data: @Json.Serialize(Model.CategoryData),
                backgroundColor: categoryColors,
