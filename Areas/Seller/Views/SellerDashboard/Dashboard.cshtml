                            </div>
                            <div class="card-content">
                                <p class="mb-2 fw-medium">Avg. Client Rating</p>
                                <h3 class="text-bold mb-1">7.8/10</h3>
                                <p class="d-flex align-items-center gap-2 fw-medium text-sm">
                                    <span class="d-inline-flex align-items-center gap-2 text-success-2">
                                        <i class="lni lni-arrow-top-right"></i>
                                        +2.5%
                                    </span>
                                    <span class="text-gray">than last Week</span>
                                </p>
                            </div>
                        </div>
                        <!-- End Icon Cart -->
                    </div>
                    <!-- End Col -->
                    <div class="col-lg-4 col-sm-6">
                        <div class="icon-card icon-card-4 mb-30">
                            <div class="icon blue-light">
                                <svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M2.16663 21.8833C2.16663 22.9603 3.01542 23.8333 4.06246 23.8333H15.4375C16.4845 23.8333 17.3333 22.9603 17.3333 21.8833C17.3333 17.5756 13.9381 14.0833 9.74996 14.0833C5.5618 14.0833 2.16663 17.5756 2.16663 21.8833Z"
