                            </div>
                            <div class="card-content">
                                <p class="mb-2 fw-medium">Google Ads CPC</p>
                                <h3 class="text-bold mb-1">$5.03</h3>
                                <p class="d-flex align-items-center gap-2 fw-medium text-sm">
                                    <span class="d-inline-flex align-items-center gap-2 text-success-2">
                                        <i class="lni lni-arrow-top-right"></i>
                                        +2.6%
