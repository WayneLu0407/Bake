@model Bake.Areas.Seller.ViewModels.ProductViewModel

@if (TempData["Success"] != null)
{
    <script>
        alert("@Html.Raw(TempData["Success"])");
    </script>
}
        <!-- ========== section start ========== -->
        <section>
            <div class="container-fluid">
                <!-- ========== title-wrapper start ========== -->
                <div class="title-wrapper pt-30">
                    <div class="row justify-content-center">
                        <div class="col-md-4">
                            <div class="title d-flex align-items-center flex-wrap justify-content-center">
                                <h2 class="mr-40">新增商品</h2>
                            </div>
                        </div>
                    </div>
                    <!-- end row -->
                </div>
            </div>
                <!-- ========== title-wrapper end ========== -->
                <!-- ======== card style start ========== -->
                <div class="card-style px-0 mb-30">

                    <div class="row justify-content-center">
                        <div class="col-md-4">
                            <form asp-area="Seller" asp-controller="SellerProduct" asp-action="New" method="post" enctype="multipart/form-data" novalidate>
                                @Html.AntiForgeryToken()
                                
                                <div class="form-group">
                                    <label asp-for="ProductName" class="control-label"></label>
                                    <input asp-for="ProductName" class="form-control" />
                                    <span asp-validation-for="ProductName" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="CategoryId" class="control-label"></label>
                                    <select asp-for="CategoryId" class="form-control"
                                            asp-items="@(new SelectList(ViewBag.Categories, "CategoryId", "CategoryName"))">
                                            <option value="">-- 請選擇分類 --</option>
                                    </select>
                                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="ProductDescription" class="control-label"></label>
                                    <input asp-for="ProductDescription" class="form-control" />
                                    <span asp-validation-for="ProductDescription" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="ProductPrice" class="control-label"></label>
                                    <input asp-for="ProductPrice" class="form-control" type="text" data-val-number="請輸入有效的數字" />
                                    <span asp-validation-for="ProductPrice" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="ProductDiscount" class="control-label"></label>
                                    <input asp-for="ProductDiscount" class="form-control" type="text" data-val-number="請輸入有效的數字" min="0" min="0.99"  data-val-range="數字必須介於0到0.99之間" />
                                    <span asp-validation-for="ProductDiscount" class="text-danger"></span>

                                </div>
                                <div class="form-group">
                                    <label asp-for="ProductQuantity" class="control-label"></label>
                                    <input asp-for="ProductQuantity" class="form-control" min="1" step="1" data-val-range="數量必須大於 0"
                                    data-val-number="請輸入有效的數字" data-val-step="請輸入整數 (不可有小數點)" />
                                    <span asp-validation-for="ProductQuantity" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="ExpireDate" class="control-label"></label>
                                    <input asp-for="ExpireDate" class="form-control" type="date" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                    <span asp-validation-for="ExpireDate" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="Ingredients" class="control-label"></label>
                                    <input asp-for="Ingredients" class="form-control" rows="3" />
                                    <span asp-validation-for="Ingredients" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="NetWeight" class="control-label"></label>
                                    <input asp-for="NetWeight" class="form-control"  />
                                    <span asp-validation-for="NetWeight" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="ShelfLifeNote" class="control-label"></label>
                                    <input asp-for="ShelfLifeNote" class="form-control" />
                                    <span asp-validation-for="ShelfLifeNote" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="ProductImage" class="control-label"></label>
                                    <img src="~/ProductPicture/NoImage.jpg" style="height:270px; display:block; margin-bottom:15px;" />
                                    <input type="file" asp-for="ProductImage" class="form-control" accept="image/*" title="尚無內容" />
                                    <span asp-validation-for="ProductImage" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <input type="submit" value="新增" class="btn btn-primary" />
                                </div>
                            </form>
                        </div>
                    </div>
                <!-- ======== card style end ========== -->
               
            </div>
            <!-- end container -->
        </section>
        <!-- ========== section end ========== -->
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function () {
            // 強制覆蓋 jQuery Validation 的所有預設訊息，不讓它有機會噴英文
            if ($.validator) {
                $.extend($.validator.messages, {
                    required: "此欄位為必填",
                    remote: "請修正此欄位",
                    email: "請輸入有效的電子郵件",
                    url: "請輸入有效的網址",
                    date: "請輸入有效的日期",
                    number: "請輸入有效的數字",
                    digits: "請只輸入數字",
                    equalTo: "請再次輸入相同的值",
                    maxlength: $.validator.format("最多輸入 {0} 個字"),
                    minlength: $.validator.format("最少輸入 {0} 個字"),
                    step: $.validator.format("請輸入整數"),
                    range: $.validator.format("請輸入介於 {0} 到 {1} 之間的數值"),
                    max: $.validator.format("數值不能大於 {0}"),
                    min: $.validator.format("數值必須大於或等於 {0}") // 這行就是解決 0 變英文的關鍵
                });
            }
            // 強化數字驗證邏輯：如果不是數字，就直接回傳錯誤，不要再跑後面的 min 驗證
            var originalNumberMethod = $.validator.methods.number;
            $.validator.methods.number = function (value, element) {
                return this.optional(element) || /^-?(?:\d+|\d{1,3}(?:,\d{3})+)?(?:\.\d+)?$/.test(value);
            };
            // 修正小數點與 Range 的相容性（維持之前加強的部分）
            $.validator.methods.number = function (value, element) {
                return this.optional(element) || /^-?(?:\d+|\d{1,3}(?:,\d{3})+)?(?:\.\d+)?$/.test(value);
            };

            $.validator.methods.range = function (value, element, param) {
                var globalizedValue = value.replace(",", ".");
                return this.optional(element) || (globalizedValue >= param[0] && globalizedValue <= param[1]);
            };
            // 針對整數欄位的特別處理：確保 step 驗證也能過
            $.validator.methods.step = function (value, element, param) {
                return this.optional(element) || (value % param === 0);
            };
        });
        function previewUploadImage(inputFile) {
            var file = inputFile.files[0];

            if(file.size>5*1024*1024){
                alert("圖片不能超過5MB");
                inputFile.value="";
                return;
            }
            var allowTypes = "image.*";
            if (inputFile.files[0].type.match(allowTypes)) {
                $('.btn').prop('disabled', false);
                var reader = new FileReader();
                reader.onload = function (e) {
                    $("#ProductImage").prev().attr('src', e.target.result);
                    $("#ProductImage").prev().attr('title', file.name);
                }
                reader.readAsDataURL(file);
            }
            else {
                alert("不支援上傳的檔案格式!");
                inputFile.value = "";
                $('.btn').prop('disabled', true);

                $("#ProductImage").prev().attr('src', "/images/NoImage.jpg");
                $("#ProductImage").prev().attr('title', "尚無圖片");

            }
        }

        $("#ProductImage").change(function () {
            // alert("change");
                previewUploadImage(this);
        });

    </script>
}
