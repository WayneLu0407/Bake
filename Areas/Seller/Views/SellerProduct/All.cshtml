@model IEnumerable<Bake.Areas.Seller.ViewModels.ProductListViewModel>
<!-- ========== section start ========== -->
<section>
    <div class="container-fluid">
        <!-- ========== title-wrapper start ========== -->
        <div class="title-wrapper pt-30">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <div class="title d-flex align-items-center flex-wrap">
                        <h2 class="mr-40">修改商品</h2>
                    </div>
                </div>
            </div>
            <!-- end row -->
        </div>
        <!-- ========== title-wrapper end ========== -->
        <!-- ======== card style start ========== -->
        <div class="card-style px-0 mb-30">
            <div class="title d-flex flex-wrap pl-30 pr-30 mb-10 align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <h6>排序:</h6>
                    <div class="select-style-1 mb-0 ml-10">
                        <div class="select-position">
                            <select class="p-0 pe-5 border-0">
                                <option value="">日期</option>
                                <option value="">品名</option>
                            </select>
                        </div>
                    </div>
                    <p>
                        <a asp-action="New">Create New</a>
                    </p>
                </div>
            </div>
            <div class="table-wrapper table-responsive task-table">
                <table class="table">
                    <thead>
                        <tr>
                            <th class ="min-width">商品名稱</th>
                            <th class="min-width">商品分類</th>
                            <th class="min-width">商品描述</th>
                            <th class="min-width">商品數量</th>
                            <th class="min-width">商品圖片</th>
                            <th class="min-width"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="min-width">
                                    <h5 class="text-bold text-dark">
                                        @item.ProductName
                                    </h5>
                                </td>
                                <td class="min-width ">
                                    <p>
                                        @item.CategoryName
                                    </p>
                                </td>
                                <td class="min-width">
                                    <p>
                                        @item.ProductDescription
                                    </p>
                                </td>
                                <td class="min-width">
                                    <p> @item.ProductQuantity</p>
                                </td>
                                <td class="min-width">
                                    <div class="employee-image mx-auto">
                                        <img src="~/@item.ProductImage" style="height:50px" alt="" />
                                    </div>
                                </td>
                                <td class="min-width">
                                    <div class="action justify-content-end">
                                        <button class="text-dark link-btn">
                                            <a asp-area="Seller" asp-controller="SellerProduct" asp-action="Edit"
                                               asp-route-id="@item.ProductId"></a>
                                            <i class="lni lni-pencil"></i>
                                        </button>
                                        <!-- 刪除按鈕，必須用 form POST -->
                                        <form asp-area="Seller" asp-controller="SellerProduct"
                                              asp-action="Delete" asp-route-id="@item.ProductId"
                                              method="post" style="display:inline"
                                              onsubmit="return confirm('確定要刪除【@item.ProductName】？')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="text-dark delete-btn ml-10">
                                                <i class="lni lni-trash-can"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <!-- end table -->
            </div>
        </div>
        <!-- ======== card style end ========== -->

    </div>
    <!-- end container -->
</section>
<!-- ========== section end ========== -->
