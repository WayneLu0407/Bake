<!-- Bootstrap編輯的modal畫面 -->
    <div class="modal fade" id="profileEditModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">編輯個人資料</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div id="profileEditErrors" class="alert alert-danger d-none"></div>

                    <form id="profileEditForm" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <img id="editAvatarPreview"
                                         src="~/seller_assets/images/profile/NoImage.png"
                                         alt="頭像預覽"
                                         style="width:100%; max-width:220px; border-radius:16px; object-fit:cover;" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">頭像</label>
                                    <input type="file"
                                           id="editAvatarFile"
                                           name="AvatarFile"
                                           class="form-control"
                                           accept=".jpg,.jpeg,.png" />
                                </div>
                            </div>

                            <div class="col-md-8">

                                <div class="mb-3">
                                    <label class="form-label">顯示名稱</label>
                                    <input type="text" id="editFullName" name="FullName" class="form-control" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">個人介紹</label>
                                    <textarea id="editBio" name="Bio" class="form-control" rows="5"></textarea>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="button" id="saveProfileBtn" class="btn btn-primary">儲存</button>
                </div>
            </div>
        </div>
    </div>

<!-- modal的JS資料弄進去 -->

@section Scripts {
    <script>
        $(function () {

            $("#openProfileEditModal").on("click", function () {
                $("#profileEditErrors").addClass("d-none").empty();

                $.get('@Url.Action("GetProfileEditJson", "Me", new { area = "Seller" })', function (res) {
                    if (!res.success) {
                        alert(res.message || "讀取資料失敗");
                        return;
                    }

                    const data = res.data;

                    $("#editFullName").val(data.fullName);
                    $("#editBio").val(data.bio);
                    $("#editAvatarPreview").attr("src", data.avatarUrl);
                    $("#editAvatarFile").val("");

                    $("#profileEditModal").modal("show");
                }).fail(function () {
                    alert("讀取資料失敗，請稍後再試");
                });
            });

            $("#editAvatarFile").on("change", function () {
                const file = this.files[0];
                if (!file) return;

                const reader = new FileReader();
                reader.onload = function (e) {
                    $("#editAvatarPreview").attr("src", e.target.result);
                };
                reader.readAsDataURL(file);
            });

            $("#saveProfileBtn").on("click", function () {
                $("#profileEditErrors").addClass("d-none").empty();

                const form = $("#profileEditForm")[0];
                const formData = new FormData(form); //配合傳圖

                $.ajax({
                    url: '@Url.Action("UpdateProfileJson", "Me", new { area = "Seller" })',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (res) {
                        if (res.success) {
                            $("#profileEditModal").modal("hide");
                            location.reload();
                            return;
                        }

                        let messages = [];

                        if (res.errors && res.errors.length > 0) {
                            messages = res.errors;
                        } else if (res.message) {
                            messages = [res.message];
                        } else {
                            messages = ["儲存失敗"];
                        }

                        let html = "<ul class='mb-0'>";
                        $.each(messages, function (index, msg) {
                            html += `<li>${msg}</li>`;
                        });
                        html += "</ul>";

                        $("#profileEditErrors").html(html).removeClass("d-none");
                    },
                    error: function () {
                        $("#profileEditErrors")
                            .html("<ul class='mb-0'><li>系統忙碌中，請稍後再試</li></ul>")
                            .removeClass("d-none");
                    }
                });
            });

        });
    </script>
}
