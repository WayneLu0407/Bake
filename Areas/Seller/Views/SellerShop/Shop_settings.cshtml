@model Bake.Areas.Seller.ViewModels.SellerShopSettingsReadViewModel

@{
    ViewData["Title"] = "Shop_settings";

    string? shopImageUrl = null;

    if (!string.IsNullOrWhiteSpace(Model?.ShopImg) &&
        !Model.ShopImg.StartsWith("http://") &&
        !Model.ShopImg.StartsWith("https://"))
    {
        shopImageUrl = Url.Content("~/" + Model.ShopImg.TrimStart('/'));
    }
}

<div class="container my-4">
    <div class="row g-4">

        <!-- 右側內容 -->
        <div class="col-12 col-lg-9">
            <div class="seller-panel p-4 rounded-4">

                <div class="mb-3">
                    <div class="fs-4 fw-bold">店舖設定</div>
                    <div class="text-muted">店舖簡介</div>
                </div>

                <div class="seller-card bg-white rounded-4 p-4 shadow-sm">

                    <!-- 頭像 + 店名 + 簡介 -->
                    <div class="d-flex flex-column flex-md-row gap-4 align-items-start">
                        <div class="position-relative">
                            <!-- 功用：正式卡片顯示店鋪頭像 -->
                            <!-- 若 shopImageUrl 有值就顯示圖片，否則顯示 📷 -->
                            <div class="seller-avatar bg-secondary-subtle d-flex align-items-center justify-content-center overflow-hidden">
                                @if (!string.IsNullOrWhiteSpace(shopImageUrl))
                                {
                                    <img src="@shopImageUrl"
                                         alt="店舖圖片"
                                         class="w-100 h-100"
                                         style="object-fit:cover;"
                                         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                }

                                <div class="shop-image-fallback d-flex align-items-center justify-content-center w-100 h-100"
                                     style="display:@(string.IsNullOrWhiteSpace(shopImageUrl) ? "flex" : "none");">
                                    📷
                                </div>
                            </div>

                            <!-- 這個按鈕目前先保留樣式，不做功能 -->
                            <button type="button" class="btn btn-light btn-sm seller-avatar-btn" title="更換頭像">
                                📷
                            </button>
                        </div>

                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <!-- 顯示目前店鋪名稱 -->
                                <h3 class="mb-0 fw-bold">@Model.ShopName</h3>
                                <!-- 改成可套tagHelper&編輯還沒做 -->
                                <button type="button" class="btn btn-outline-secondary btn-sm" title="編輯店名">✎</button>
                            </div>

                            <div class="d-flex align-items-start justify-content-between gap-2">
                                <p class="text-muted mb-0" style="line-height:1.8;">
                                    @Model.ShopDescription
                                </p>
                                <!-- 改成可套tagHelper&編輯還沒做 -->
                                <button type="button" class="btn btn-outline-secondary btn-sm flex-shrink-0" title="編輯店舖介紹">
                                    ✎
                                </button>
                            </div>

                    <hr class="my-4" />

                    <!-- 社群連結 -->
                    <div class="mb-3">
                        <label class="form-label">連結FB</label>
                        <input class="form-control" placeholder="https://facebook.com/..." />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">連結IG</label>
                        <input class="form-control" placeholder="https://instagram.com/..." />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">連結YT</label>
                        <input class="form-control" placeholder="https://youtube.com/..." />
                    </div>

                    <div class="mb-4">
                        <label class="form-label">連Pinterest</label>
                        <input class="form-control" placeholder="https://pinterest.com/..." />
                    </div>

                    <!-- 按鈕 -->
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-warning px-4">預覽</button>
                        <button type="button" class="btn btn-warning px-4">儲存</button>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>