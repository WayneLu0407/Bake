@model IEnumerable<Bake.Areas.Seller.ViewModels.OrderListViewModel>
@using Bake.Enum

<body>
    <!-- ========== table components start ========== -->
    <section class="table-components">
        <div class="container-fluid">
            <!-- ========== title-wrapper start ========== -->
            <div class="title-wrapper pt-30">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <div class="title">
                            <h2>訂單管理</h2>
                        </div>
                    </div>
                    <!-- end col -->
                    <div class="col-md-6">
                        <div class="breadcrumb-wrapper">
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb">
                                </ol>
                                <div class="btn-group">
                                    <a href="@Url.Action("Orders", "SellerOrder")"
                                       class="btn btn-outline-primary btn-sm @(Context.Request.Query["statusId"].ToString() == "" ? "active" : "")">全部</a>
    
                                    <a href="@Url.Action("Orders", "SellerOrder", new { statusId = (int)OrderStatusEnum.Paid })"
                                       class="btn btn-outline-warning btn-sm @(Context.Request.Query["statusId"].ToString() == ((int)OrderStatusEnum.Paid).ToString() ? "active" : "")">待出貨</a>
    
                                    <a href="@Url.Action("Orders", "SellerOrder", new { statusId = (int)OrderStatusEnum.Shipped })"
                                       class="btn btn-outline-success btn-sm @(Context.Request.Query["statusId"].ToString() == ((int)OrderStatusEnum.Shipped).ToString() ? "active" : "")">已出貨</a>
                                </div>
                            </nav>
                        </div>
                    </div>
                    <!-- end col -->
                </div>
                <!-- end row -->
            </div>
             
            <!-- ========== tables-wrapper start ========== -->
            <div class="tables-wrapper">
                <!-- end row -->
                <div class="row">
                    <div class="col-lg-12">
                        <div class="card-style mb-30">
                            @* <h6 class="mb-10">Basic Example</h6> *@
                            <div class="table-wrapper table-responsive">
                                <table class="table clients-table">
                                    <thead>
                                        <tr>
                                            <th>
                                                <h6>訂單編號</h6>
                                            </th>
                                            <th>
                                                <h6>客戶姓名</h6>
                                            </th>
                                            <th>
                                                <h6>Email</h6>
                                            </th>
                                            <th>
                                                <h6>訂單內容</h6>
                                            </th>
                                            <th>
                                                <h6>出貨狀態</h6>
                                            </th>
                                            <th>
                                                <h6>下單時間</h6>
                                            </th>
                                            <th>
                                                <h6>訂單金額</h6>
                                            </th>
                                            <th><h6>操作</h6></th>
                                        </tr>
                                        <!-- end table row-->
                                    </thead>
                                    <tbody>
                                        @if (Model != null && Model.Any())
                                        {
                                            @foreach (var item in Model)
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="min-width">
                                                            <div class="d-flex justify-content-center align-items-center">
                                                                <p>訂單編號: #@item.OrderId</p>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td class="min-width">
                                                        <p>@item.UserName</p>
                                                    </td>
                                                    <td class="min-width">
                                                        <p><a href="mailto:@item.Email">@item.Email</a></p>
                                                    </td>
                                                    <td class="min-width">
                                                        @foreach (var product in item.Products)
                                                        {
                                                        <p>@product.ProductName</p> <p>數量：@product.Quantity</p>
                                                        }
                                                    </td>
                                                    <td>
                                                        @{
                                                            var statusClass = "active-btn"; // 預設
                                                            if (item.StatusId == (int)OrderStatusEnum.Paid) statusClass = "warning-btn";
                                                            if (item.StatusId == (int)OrderStatusEnum.Shipped) statusClass = "success-btn";
                                                            if (item.StatusId == (int)OrderStatusEnum.Cancelled) statusClass = "close-btn";
                                                        }
                                                        <span class="status-btn @statusClass">@item.StatusName</span>
                                                    </td>
                                                    <td class="min-width">
                                                        <p>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</p>
                                                    </td>
                                                    <td>
                                                        <p>$@item.TotalAmount.ToString("N0")</p>
                                                    </td>
                                                    <td>
                                                        @if (item.StatusId == (int)OrderStatusEnum.Paid)
                                                        {
                                                            <button class="btn btn-sm btn-primary" onclick="shipOrder(@item.OrderId)">一鍵出貨</button>
                                                        }
                                                        else
                                                        {
                                                            <button class="btn btn-sm btn-light" disabled>一鍵出貨</button>
                                                        }

                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                                <!-- end table -->
                            </div>
                        </div>
                        <!-- end card -->
                    </div>
                    <!-- end col -->
                </div>
                <!-- end row -->
            </div>
            <!-- ========== tables-wrapper end ========== -->
        </div>
        <!-- end container -->
    </section>
    <!-- ========== table components end ========== -->
</section>
   
</body>

@section Scripts
{
    <script>
        async function shipOrder(OrderId){
            
            if (!confirm(`確定要將訂單#${OrderId} 標記為已出貨嗎?`)){
                return;
            }

            try{
                const response = await fetch(`/Seller/SellerOrder/Ship/${OrderId}`,{
                    method:'POST',
                    @*body:不用body?*@
                    headers:{'Content-Type':'application/json'}
                });

                
                if(response.ok){
                    const result = await response.json();
                    if(result.success){
                        alert(result.message);
                        location.reload();
                    }
                }
                else{
                    alert('出貨失敗:'+(result.message || '未知錯誤'));
                }
            }
            catch(error)
            {
                console.error('Error', error);
                alert('系統發生錯誤，請稍後再試');
            }
        }
    </script>
}
