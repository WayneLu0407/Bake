
@{
    ViewData["Title"] = "全部文章";
}

@section Styles
{
<style>
    /* ===== 文章卡片（橫向：左圖右文） ===== */
    .post-list-card {
        border: 1px solid #eee;
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
        transition: box-shadow .25s;
    }
    .post-list-card:hover {
        box-shadow: 0 4px 16px rgba(0,0,0,.1);
    }
    .post-list-card .card-img {
        width: 180px;
        min-height: 140px;
        object-fit: cover;
        flex-shrink: 0;
        background-color: #e8e8e8;
    }
    .post-list-card .card-img-placeholder {
        width: 180px;
        min-height: 140px;
        background-color: #e8e8e8;
        flex-shrink: 0;
    }
    .post-list-card .card-body {
        padding: 16px 20px;
    }
    .post-list-card .card-title {
        font-size: 1.05rem;
        font-weight: 700;
        margin-bottom: 6px;
    }
    .post-list-card .card-text {
        font-size: .85rem;
        color: #666;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .post-list-card .card-date {
        font-size: .8rem;
        color: #999;
    }
    .post-list-card .badge-event-type {
        font-size: .75rem;
        padding: 3px 8px;
        border-radius: 4px;
    }

    /* ===== 左側篩選欄 ===== */
    .filter-section h5 {
        font-size: 1rem;
        font-weight: 700;
    }
    .filter-section .nav-link {
        font-size: .9rem;
        cursor: pointer;
    }
    .filter-section .nav-link:hover {
        color: #F5A623 !important;
    }
    .filter-section .nav-link.active-filter {
        font-weight: 700;
        color: #F5A623 !important;
    }

    /* ===== 活動額外資訊 ===== */
    .event-info {
        font-size: .8rem;
        color: #888;
    }
    .event-info i {
        width: 16px;
        text-align: center;
    }
</style>
}


<section class="py-4" id="app" v-cloak>
    <div class="container-fluid">
        <div class="row">

            <!-- ==================== 左側篩選欄 ==================== -->
            <aside class="col-4 col-lg-3 mb-4 filter-section">

                <!-- 麵包屑 -->
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-3">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">首頁</a></li>
                        <li class="breadcrumb-item"><a asp-controller="Post" asp-action="Index">交流分享區</a></li>
                        <li class="breadcrumb-item active">全部</li>
                    </ol>
                </nav>

                <!-- 內容類型 -->
                <div class="mb-4">
                    <h5 class="mb-3">內容類型</h5>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a class="nav-link px-0 active-filter" @@click.prevent="contentType='all'">全部</a></li>
                        <li class="mb-1"><a class="nav-link px-0"  @@click.prevent="contentType='post'">文章</a></li>
                        <li class="mb-1"><a class="nav-link px-0"  @@click.prevent="contentType='event'">活動</a></li>
                    </ul>
                </div>

                <hr>

                <!-- 排序 -->
                <div class="mb-4">
                    <h5 class="mb-3">排序</h5>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a class="nav-link px-0 active-filter" href="#">最新</a></li>
                        <li class="mb-1"><a class="nav-link px-0" href="#">熱門</a></li>
                    </ul>
                </div>

                <hr>

                <!-- ★ 活動類型（選「活動」時才顯示，你用 v-if 控制） -->
                <div class="mb-4">
                    <h5 class="mb-3">活動類型</h5>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a class="nav-link px-0 active-filter" href="#">全部</a></li>
                        <li class="mb-1"><a class="nav-link px-0" href="#">手作實作</a></li>
                        <li class="mb-1"><a class="nav-link px-0" href="#">經驗分享</a></li>
                        <li class="mb-1"><a class="nav-link px-0" href="#">品嚐聚會</a></li>
                        <li class="mb-1"><a class="nav-link px-0" href="#">食材揪團</a></li>
                    </ul>
                </div>

                <hr>

                <!-- ★ 活動金額（選「活動」時才顯示，你用 v-if 控制） -->
                <div class="mb-4">
                    <h5 class="mb-3">活動金額</h5>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="priceRange" id="ep0" checked>
                        <label class="form-check-label" for="ep0">全部</label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="priceRange" id="ep1">
                        <label class="form-check-label" for="ep1">免費</label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="priceRange" id="ep2">
                        <label class="form-check-label" for="ep2">NT$500 以下</label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="priceRange" id="ep3">
                        <label class="form-check-label" for="ep3">NT$500 - 1,000</label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="priceRange" id="ep4">
                        <label class="form-check-label" for="ep4">NT$1,000 以上</label>
                    </div>
                </div>

            </aside>

            <!-- ==================== 右側內容區 ==================== -->
            <div class="col-8 col-lg-9">

                <!-- 結果數量 -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted small">共 20 筆結果</span>
                </div>

                <!-- 文章/活動列表 -->
                <div class="d-flex flex-column gap-3">
                    <a v-for="item in allPosts" :key="postId" :href="'/Post/PostDetail/'+ item.postId" class="text-decoration-none text-dark">
                        <div class="post-list-card d-flex">
                            <img v-if="item.image":src="item.image" :alt="item.title" class="card-img" />
                            <div  v-else class="card-body d-flex flex-column justify-content-center">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <span class="card-date">{{item.createdAt}}</span>
                                    <span v-if="item.typeId ===1"class="badge bg-warning text-dark badge-event-type">活動</span>
                                    <span v-if="item.eventTypeName"class="badge bg-light text-muted badge-event-type">{{item.eventTypeName}}</span>
                                </div>
                                <h5 class="card-title">{{item.title}}</h5>
                                <p class="card-text">{{item.content}}</p>
                                <!-- 活動才有的額外資訊 -->
                                <div v-if="item.typeId===1"class="event-info d-flex gap-3 mt-1">
                                    <span><i class="fa-regular fa-calendar"></i> {{item.eventTime}}</span>
                                    <span><i class="fa-solid fa-location-dot"></i> {{item.locationCity }}</span>
                                    <span><i class="fa-solid fa-tag"></i>{{item.price===0?'免費':'NT$' + item.price}}</span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>

                <!-- 分頁 -->
                <div class="d-flex justify-content-center align-items-center gap-2 mt-4">
                    <nav>
                        <ul class="pagination mb-0">
                            <li class="page-item disabled"><a class="page-link" href="#">«</a></li>
                            <li class="page-item active"><a class="page-link rounded-3" href="#">1</a></li>
                            <li class="page-item"><a class="page-link rounded-3" href="#">2</a></li>
                            <li class="page-item"><a class="page-link rounded-3" href="#">3</a></li>
                            <li class="page-item"><a class="page-link" href="#">»</a></li>
                        </ul>
                    </nav>
                    <div class="d-flex align-items-center gap-2 ms-3">
                        <span class="text-muted small">前往頁面</span>
                        <input type="number" class="form-control form-control-sm" style="width: 60px;" value="1" min="1">
                    </div>
                </div>

            </div>
            <!-- / 右側內容區 -->

        </div>
    </div>
</section>

 @section Scripts
{
    <script>
        const app = Vue.createApp({
            data(){
                return{
                    allPosts:[],
                    contentType:'all',
                    sortBy:'latest',
                    eventType: 'all',
                    priceRange:'all',
                }
            },
            async mounted() {

                // 從contenttype怎麼來的開始
                try{
                    const res= await fetch('/api/PostApi/All')
                    this.allPosts = await res.json()
                }catch(err){
                    console.error(err.message) 
                }

                try{
                    const res2= await fetch('/api/PostApi/EventTypes')
                    this.raw = await res2.json()
                    this.eventType=raw.filter(this=>t.eventType!==0)
                }catch(err){
                    console.error(err.message) 
                }
            
            },
            methods: {},
            computed:{
                filteredList(){
                    let list=[...this.allPosts]

                    if(this.contentType==='post'){
                        list =list.filter(p=>p.typeId===0)
                    }else if(this.contentType==='event'){
                        list =list.filter(p=>p.typeId===1)
                    }

                    if(this.contentType==='event'&&this.eventType!='all'){
                        list=list.filter(p=>p.eventType ===this.eventType)
                    }

                    if(this.contentType==='event'&&this.priceRange !='all'){
                        if(this.priceRange === 'free'){
                            list=list.filter(p=>p.price ===0||p.price===null)
                        }else{
                            const [min,max]=this.priceRange.split('-').map(Number)
                            list = list.filter(p => p.price >= min && p.price <= max)
                        }
                    }
                },
                contentType(){
                    const map={0:'心得貼文',1:'活動貼文'}
                    return map[this.contentType]
                }
            },
        }).mount('#app')
    </script>
}