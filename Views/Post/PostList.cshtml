
@{
    ViewData["Title"] = "全部文章";
}

@section Styles
{
<style>
    /* ===== 文章卡片（橫向：左圖右文） ===== */
    .post-list-card {
        border: 1px solid #eee;
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
        transition: box-shadow .25s;
    }
    .post-list-card:hover {
        box-shadow: 0 4px 16px rgba(0,0,0,.1);
    }
    .post-list-card .card-img {
        width: 180px;
        min-height: 140px;
        object-fit: cover;
        flex-shrink: 0;
        background-color: #e8e8e8;
    }
    .post-list-card .card-img-placeholder {
        width: 180px;
        min-height: 140px;
        background-color: #e8e8e8;
        flex-shrink: 0;
    }
    .post-list-card .card-body {
        padding: 16px 20px;
    }
    .post-list-card .card-title {
        font-size: 1.05rem;
        font-weight: 700;
        margin-bottom: 6px;
    }
    .post-list-card .card-text {
        font-size: .85rem;
        color: #666;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .post-list-card .card-date {
        font-size: .8rem;
        color: #999;
    }
    .post-list-card .badge-event-type {
        font-size: .75rem;
        padding: 3px 8px;
        border-radius: 4px;
    }

    /* ===== 左側篩選欄 ===== */
    .filter-section h5 {
        font-size: 1rem;
        font-weight: 700;
    }
    .filter-section .nav-link {
        font-size: .9rem;
        cursor: pointer;
    }
    .filter-section .nav-link:hover {
        color: #F5A623 !important;
    }
    .filter-section .nav-link.active-filter {
        font-weight: 700;
        color: #F5A623 !important;
    }

    /* ===== 活動額外資訊 ===== */
    .event-info {
        font-size: .8rem;
        color: #888;
    }
    .event-info i {
        width: 16px;
        text-align: center;
    }
</style>
}


<section class="py-4" id="app" v-cloak>
    <div class="container-fluid">
        <div class="row">

            <!-- ==================== 左側篩選欄 ==================== -->
            <aside class="col-4 col-lg-3 mb-4 filter-section">

                <!-- 麵包屑 -->
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-3">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">首頁</a></li>
                        <li class="breadcrumb-item"><a asp-controller="Post" asp-action="Index">交流分享區</a></li>
                        <li class="breadcrumb-item active">{{breadcrumbLabel}}</li>
                    </ol>
                </nav>

                <!-- 內容類型 -->
                <div class="mb-4">
                    <h5 class="mb-3">內容類型</h5>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a class="nav-link px-0" :class="{'active-filter':contentType === 'all'}" @@click.prevent="contentType='all'">全部</a></li>
                        <li class="mb-1"><a class="nav-link px-0" :class="{'active-filter':contentType === 'post'}" @@click.prevent="contentType='post'">文章</a></li>
                        <li class="mb-1"><a class="nav-link px-0" :class="{'active-filter':contentType === 'event'}" @@click.prevent="contentType='event'">活動</a></li>
                    </ul>
                </div>


                <!-- 排序 -->
                <div class="mb-4">
                    <h5 class="mb-3">排序</h5>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a class="nav-link px-0" :class="{'active-filter':sortBy === 'latest'}" @@click.prevent="sortBy = 'latest'">最新</a></li>
                        <li class="mb-1"><a class="nav-link px-0" :class="{'active-filter':sortBy === 'hot'}" @@click.prevent="sortBy = 'hot'">熱門</a></li>
                    </ul>
                </div>

                <template v-if="contentType === 'event'">
                    <hr>

                    <!-- ★ 活動類型（選「活動」時才顯示，你用 v-if 控制） -->
                    <div class="mb-4">
                        <h5 class="mb-3">活動類型</h5>
                        <ul class="list-unstyled">
                            <li class="mb-1"><a class="nav-link px-0" :class="{'active-filter':eventType === 'all'}" @@click.prevent="eventType='all'">全部</a></li>
                            <li class="mb-1" v-for ="t in eventTypes" :key="t.eventTypeId"><a class="nav-link px-0" :class="{'active-filter':eventType === t.eventTypeId}" @@click.prevent="eventType=t.eventTypeId">{{t.eventTypeName}}</a></li>
                        </ul>
                    </div>

                  
                    <div class="mb-4">
                        <h5 class="mb-3">活動金額</h5>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" v-model="priceRange"value="all" id="ep0">
                            <label class="form-check-label" for="ep0">全部</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" v-model="priceRange"value="free" id="ep1">
                            <label class="form-check-label" for="ep1">免費</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" v-model="priceRange"value="1-500" id="ep2">
                            <label class="form-check-label" for="ep2">NT$500 以下</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" v-model="priceRange" value="501-1000"id="ep3">
                            <label class="form-check-label" for="ep3">NT$500 - 1,000</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" v-model="priceRange"value="1001-9999" id="ep4">
                            <label class="form-check-label" for="ep4">NT$1,000 以上</label>
                        </div>
                    </div>
                </template>
            </aside>

            <!-- ==================== 右側內容區 ==================== -->
            <div class="col-8 col-lg-9">

                <!-- 結果數量 -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted small">共 {{ filteredList.length }} 筆結果</span>
                </div>

                <!-- 文章/活動列表 -->
                <div class="d-flex flex-column gap-3">
                    <a v-for="item in pagedList" :key="item.postId" :href="'/Post/PostDetail/'+ item.postId" class="text-decoration-none text-dark">
                        <div class="post-list-card d-flex">
                            <img v-if="item.image":src="item.image" :alt="item.title" class="card-img" />
                            <div v-else class="card-img-placeholder"></div>
                            <div class="card-body d-flex flex-column justify-content-center">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <span class="card-date">{{formatDate(item.createdAt)}}</span>
                                    <span v-if="item.typeId ===1"class="badge bg-warning text-dark badge-event-type">活動</span>
                                    <span v-if="item.eventTypeName"class="badge bg-light text-muted badge-event-type">{{item.eventTypeName}}</span>
                                </div>
                                <h5 class="card-title">{{item.title}}</h5>
                                <p class="card-text">{{item.content}}</p>
                                <!-- 活動才有的額外資訊 -->
                                <div v-if="item.typeId ===1"class="event-info d-flex gap-3 mt-1">
                                    <span><i class="fa-regular fa-calendar"></i> {{formatDate(item.eventTime)}}</span>
                                    <span><i class="fa-solid fa-location-dot"></i> {{item.locationCity }}</span>
                                    <span><i class="fa-solid fa-tag"></i>{{(item.price === 0 || item.price === null)?'免費':'NT$' + item.price}}</span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>

                <div v-if="filteredList.length ===0" class="text py-5 text-muted">
                    <i class="fa-regular fa-face-meh fa-3x mb-3"></i>
                    <p>目前沒有符合條件的內容</p>
                </div>

                <!-- 分頁 -->
                <div class="d-flex justify-content-center align-items-center gap-2 mt-4" v-if="totalPages > 1">
                    <nav>
                        <ul class="pagination mb-0">
                            <li class="page-item" :class="{disabled:currentPage===1}">
                                <a class="page-link" href="#" @@click.prevent="currentPage > 1 ? currentPage-- : null">«</a>
                            </li>
                            <li class="page-item" :class="{active:currentPage===page}"  v-for="page in totalPages" :key="page">
                                <a class="page-link rounded-3" href="#" @@click.prevent="currentPage = page">{{ page }}</a>
                            </li>
                            <li class="page-item" :class="{disabled: currentPage === totalPages}">
                                <a class="page-link" href="#" @@click.prevent="currentPage < totalPages? currentPage++ :null">»</a>
                            </li>
                        </ul>
                    </nav>
                    <div class="d-flex align-items-center gap-2 ms-3">
                        <span class="text-muted small">前往頁面</span>
                        <input type="number" class="form-control form-control-sm" style="width: 60px;" min="1" :max="totalPages" v-model.number="goToPage" @@change="handleGoToPage">
                    </div>
                </div>

            </div>
            <!-- / 右側內容區 -->

        </div>
    </div>
</section>

 @section Scripts
{
    <script>
        const app = Vue.createApp({
            data(){
                return{
                    allPosts:[],
                    eventTypes: [],

                    contentType:'all',
                    sortBy:'latest',
                    eventType: 'all',
                    priceRange:'all',

                    currentPage:1,
                    pageSize:8,
                    goToPage:1,
                }
            },
            async mounted() {

                const params = new URLSearchParams(window.location.search)
                const cat = params.get('category')
                if(cat){
                    this.contentType='event'
                    this.eventType=parseInt(cat)
                }
                const type = params.get('type')
                if(type === 'post'){
                    this.contentType = 'post'
                }
                if(type === 'event'){
                    this.contentType = 'event'
                }

                try{
                    const res= await fetch('/api/PostApi/All')
                    this.allPosts = await res.json()
                }catch(err){
                    console.error(err.message) 
                }

                try{
                    const res2= await fetch('/api/PostApi/EventTypes')
                    const raw = await res2.json()
                    this.eventTypes=raw.filter(t=> t.eventTypeId!==0)
                }catch(err){
                    console.error(err.message) 
                }
            
            },
            methods: {
                formatDate(dateStr) {
                    if (!dateStr) return '';
                    return dateStr.split('T')[0];
                },
                handleGoToPage(){
                    if(this.goToPage>=1 && this.goToPage <= this.totalPages){
                        this.currentPage = this.goToPage;
                    }
                    else{
                        this.goToPage = this.currentPage;
                    }
                }
            },
            computed:{
                filteredList(){
                    let list=[...this.allPosts]

                    if(this.contentType==='post'){
                        list =list.filter(p=>p.typeId===0)
                    }else if(this.contentType==='event'){
                        list =list.filter(p=>p.typeId===1)
                    }

                    if(this.contentType==='event'&&this.eventType!='all'){
                        list=list.filter(p=>p.eventTypeId ===this.eventType)
                    }

                    if(this.contentType==='event'&&this.priceRange !='all'){
                        if(this.priceRange === 'free'){
                            list=list.filter(p=>p.price ===0||p.price===null)
                        }else{
                            const [min,max]=this.priceRange.split('-').map(Number)
                            list = list.filter(p => p.price >= min && p.price <= max)
                        }
                    }
                    if(this.sortBy==='latest'){
                        list.sort((a,b)=>new Date(b.createdAt)-new Date(a.createdAt))
                    }else if(this.sortBy === 'hot'){
                        list.sort((a,b)=>(b.viewCount||0)-(a.viewCount||0))
                    }
                    return list
                },
                totalPages(){
                    return Math.ceil(this.filteredList.length / this.pageSize)
                },
                pagedList(){
                    const start=(this.currentPage-1)*this.pageSize
                    return this.filteredList.slice(start,start+this.pageSize)
                },
                breadcrumbLabel() {
                    if (this.contentType === 'post') return '文章'
                    if (this.contentType === 'event') return '活動'
                    return '全部'
                }
            },
            watch:{
                contentType(){
                    this.currentPage=1
                    if(this.contentType !== 'event'){
                        this.eventType = 'all'
                        this.priceRange = 'all'
                    }
                },
                sortBy()     { this.currentPage = 1 },
                eventType()  { this.currentPage = 1 },
                priceRange() { this.currentPage = 1 },
            }
        }).mount('#app')
    </script>
}