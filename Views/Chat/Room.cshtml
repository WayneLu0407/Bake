@model Bake.ViewModel.ChatRoomPageViewModel

@{
    ViewData["Title"] = "聊天室";
}
<style>
        .msg-right {
            display: flex;
            justify-content: flex-end;
        }
        .msg-left {
            display: flex;
            justify-content: flex-start;
        }
        .msg-bubble {
            max-width: 70%;
            padding: 8px 14px;
            border-radius: 16px;
            margin-bottom: 8px;
        }
        .msg-right .msg-bubble {
            background-color: #dcf8c6;
        }
        .msg-left .msg-bubble {
            background-color: #f0f0f0;
        }
        .chat-list-item.active {
        background-color: #e9ecef;
        }
        .chat-list-item.active,
        .list-group-item.active {
            background-color: #ffc43f;
            border-color: #ffc43f;
            color: #333;
        }
    </style>

<div class="container py-4">
    <div class="row">
        <!-- 左邊：聊天列表 -->
        <div class="col-4">
            <h5 class="mb-3">我的訊息</h5>
            <div class="list-group" style="height: 520px; overflow-y: auto;">
                @foreach (var item in Model.ChatList)
                {
                    <a asp-action="Room" asp-route-id="@item.RoomId" class="list-group-item list-group-item-action @(item.RoomId==Model.RoomId?"active":"")" >
                        <div class="fw-bold">@item.OtherName</div>
                        <small class="text-muted">
                            @(item.LastMessage.Length>20?item.LastMessage.Substring(0, 20) + "...":item.LastMessage)
                        </small>
                        <br />
                        <small>@item.LastMessageTime.ToString("MM/dd HH:mm")</small>
                    </a>
                }
            </div>
        </div>

        <!-- 右邊：聊天室 -->
        <div class="col-8">
            <h5>@Model.RoomTitle</h5>
            <input type="hidden" id="roomId" value="@Model.RoomId" />
            <input type="hidden" id="currentUserId" value="@Model.CurrentUserId" />
            <div class="card">
                <div class="card-body" id="messageContainer" style="height: 420px; overflow-y: auto;">
                    <ul id="messageList" class="list-unstyled mb-0">
                        @foreach (var item in Model.Messages)
                        {
                            <li class="@(item.SenderId == Model.CurrentUserId ? "msg-right" : "msg-left")">
                                <div class="msg-bubble">
                                    <div>@item.Message</div>
                                    <small class="text-muted">@item.CreateDate.ToString("MM/dd HH:mm")</small>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
                <div class="card-footer">
                    <div class="input-group">
                        <input id="messageInput" type="text" class="form-control" placeholder="輸入訊息..." />
                        <button id="sendButton" class="btn btn-primary" type="button">送出</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/chat-room.js"></script>
    <script>
        // 保底：確保 preloader 一定會消失
        document.addEventListener('DOMContentLoaded', function () {
            var preloader = document.querySelector('.preloader-wrapper');
            if (preloader) {
                preloader.style.display = 'none';
            }
        });
    </script>
}