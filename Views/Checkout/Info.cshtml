
<body>
    @{
        ViewData["Title"] = "Checkout Info";
    }

    <section class="h-100 h-custom" style="background-color: #eee;">
        <div class="container py-5 h-100">
            <div class="row d-flex justify-content-center align-items-center h-100">
                <div class="col">
                    <div class="card shadow-sm" style="border-radius: 1rem; border: none;">
                        <div class="card-body p-4 p-md-5">

                            <div class="row" id="checkoutPage">

                                @* --- 左邊：收件資訊表單 --- *@
                                <div class="col-lg-7">
                                    <h5 class="mb-4">
                                        <a asp-controller="Home" asp-action="Cart" class="text-body text-decoration-none">
                                            <i class="fas fa-long-arrow-alt-left me-2"></i>Back to Cart
                                        </a>
                                    </h5>

                                    <div class="mb-4">
                                        <h3 class="fw-bold text-dark">Shipping Details</h3>
                                        <p class="text-muted">Where should we send your delicious treats?</p>
                                    </div>

                                    <form asp-controller="Checkout" asp-action="Info" method="post">
                                        <div class="mb-4">
                                            <label class="form-label fw-bold" for="ReceiverName">Receiver Name</label>
                                            <div class="input-group shadow-sm">
                                                <span class="input-group-text bg-white border-end-0"><i class="far fa-user text-muted"></i></span>
                                                <input type="text" id="ReceiverName" name="ReceiverName" class="form-control border-start-0 ps-0 form-control-lg" placeholder="e.g. John Doe" required>
                                            </div>
                                        </div>

                                        <div class="mb-4">
                                            <label class="form-label fw-bold" for="ReceiverPhone">Phone Number</label>
                                            <div class="input-group shadow-sm">
                                                <span class="input-group-text bg-white border-end-0"><i class="fas fa-mobile-alt text-muted"></i></span>
                                                <input type="tel" id="ReceiverPhone" name="ReceiverPhone" class="form-control border-start-0 ps-0 form-control-lg" placeholder="0912-345-678" required>
                                            </div>
                                        </div>

                                        <div class="mb-4">
                                            <label class="form-label fw-bold" for="ReceiverAddress">Shipping Address</label>
                                            <div class="input-group shadow-sm">
                                                <span class="input-group-text bg-white border-end-0"><i class="fas fa-map-marker-alt text-muted"></i></span>
                                                <input type="text" id="ReceiverAddress" name="ReceiverAddress" class="form-control border-start-0 ps-0 form-control-lg" placeholder="Street Address, City, Postal Code" required>
                                            </div>
                                        </div>

                                        <div class="mb-4">
                                            <label class="form-label fw-bold" for="OrderNote">Order Note (Optional)</label>
                                            <textarea id="OrderNote" name="OrderNote" class="form-control shadow-sm" rows="3" placeholder="Special delivery instructions or a message for the baker..."></textarea>
                                        </div>

                                        <button type="submit" id="realSubmitBtn" class="d-none"></button>
                                    </form>
                                </div>

                                @* --- 右邊：訂單總結 (亮黃色主題 + 圖片) --- *@
                                <div class="col-lg-5">
                                    <div class="card text-dark rounded-3 shadow-lg" style="background-color: #ffc107; border: none;">
                                        <div class="card-body p-4">
                                            <div class="d-flex justify-content-between align-items-center mb-4">
                                                <h4 class="mb-0 fw-bold">Order Summary</h4>
                                                <i class="fas fa-shopping-basket fa-lg"></i>
                                            </div>

                                            <p class="small mb-3 fw-bold" style="color: rgba(0,0,0,0.6);">Review your items</p>

                                            <div class="mb-4 overflow-auto" style="max-height: 300px; border-bottom: 1px solid rgba(0,0,0,0.1);">
                                                @* 這裡綁定你購物車的 cart 資料 *@
                                                <div v-for="item in cart" :key="item.productId" class="d-flex align-items-center mb-3 pb-2">
                                                    <div class="flex-shrink-0">
                                                        <img :src="item.imgUrl" class="img-fluid rounded-2 shadow-sm"
                                                             style="width: 60px; height: 60px; object-fit: cover; background-color: #fff;">
                                                    </div>
                                                    <div class="flex-grow-1 ms-3">
                                                        <h6 class="mb-0 fw-bold" style="font-size: 0.9rem;">{{item.productName}}</h6>
                                                        <small style="color: rgba(0,0,0,0.5);">Quantity: {{item.quantity}}</small>
                                                    </div>
                                                    <div class="text-end">
                                                        <span class="fw-bold">${{item.price * item.quantity}}</span>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="d-flex justify-content-between mb-2">
                                                <span>Subtotal</span>
                                                <span class="fw-bold">${{totalPrice}}</span>
                                            </div>

                                            <div class="d-flex justify-content-between mb-4">
                                                <span>Shipping Fee</span>
                                                <span class="fw-bold">$20.00</span>
                                            </div>

                                            <hr class="my-4" style="border-top: 2px dashed rgba(0,0,0,0.15);">

                                            <div class="d-flex justify-content-between mb-4 fs-4 fw-bolder">
                                                <span>Total</span>
                                                <span>${{totalPrice + 20}}</span>
                                            </div>

                                            @* 確認下單按鈕 (深藍色) *@
                                            <button type="button" onclick="document.getElementById('realSubmitBtn').click();"
                                                    class="btn btn-block w-100 py-3 shadow fw-bold text-white btn-lg"
                                                    style="background-color: #1A237E; border-radius: 12px; font-size: 1.1rem; border: none;">
                                                CONFIRM & PAY <i class="fas fa-chevron-right ms-2"></i>
                                            </button>

                                            <div class="text-center mt-4">
                                                <small style="color: rgba(0,0,0,0.5);">
                                                    <i class="fas fa-shield-alt me-1"></i> Your payment is secure
                                                </small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <style>
        /* 讓表單聚焦時有深藍色邊框 */
        .form-control:focus {
            border-color: #1A237E;
            box-shadow: 0 0 0 0.25rem rgba(26, 35, 126, 0.1);
        }

        .input-group-text {
            border-right: none;
        }
        /* 自定義滾動條樣式，讓它不影響黃色卡片美觀 */
        .overflow-auto::-webkit-scrollbar {
            width: 6px;
        }

        .overflow-auto::-webkit-scrollbar-thumb {
            background: rgba(0,0,0,0.1);
            border-radius: 10px;
        }
    </style>
</body>

