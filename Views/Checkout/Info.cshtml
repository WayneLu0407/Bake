@using Bake.ViewModel
@model CheckoutViewModel

@section Styles
{
    <style>
        /* 讓表單聚焦時有深藍色邊框 */
        .form-control:focus {
            border-color: #1A237E;
            box-shadow: 0 0 0 0.25rem rgba(26, 35, 126, 0.1);
        }

        .input-group-text {
            border-right: none;
        }
        /* 自定義滾動條樣式，讓它不影響黃色卡片美觀 */
        .overflow-auto::-webkit-scrollbar {
            width: 6px;
        }

        .overflow-auto::-webkit-scrollbar-thumb {
            background: rgba(0,0,0,0.1);
            border-radius: 10px;
        }
    </style>
}

<body>
    @{
        ViewData["Title"] = "Checkout Info";
    }

    <section class="h-100 h-custom" style="background-color: #eee;">
        <div class="container py-5 h-100" id="checkoutPage">
            <div class="row d-flex justify-content-center align-items-center h-100">
                <div class="col">
                    <div class="card shadow-sm" style="border-radius: 1rem; border: none;">
                        <div class="card-body p-4 p-md-5">

                            <div class="row">

                                @* --- 左邊：收件資訊表單 --- *@
                                <div class="col-lg-7">
                                    <h5 class="mb-4">
                                        <a asp-controller="Home" asp-action="Cart" class="text-body text-decoration-none">
                                            <i class="fas fa-long-arrow-alt-left me-2"></i>回到購物車
                                        </a>
                                    </h5>

                                    <div class="mb-4">
                                        <h3 class="fw-bold text-dark">配送資訊</h3>
                                        <p class="text-muted">我們該將這份美味送到哪裡給您呢？</p>
                                    </div>

                                    <form asp-controller="Checkout" asp-action="Info" method="post" id="orderForm">
                                        <div class="mb-4">
                                            <label class="form-label fw-bold" asp-for="ReceiverName">收件人姓名</label>
                                            <div class="input-group shadow-sm">
                                                <span class="input-group-text bg-white border-end-0"><i class="far fa-user text-muted"></i></span>
                                                <input asp-for="ReceiverName" type="text" class="form-control border-start-0 ps-0 form-control-lg" placeholder="e.g. John Doe" required>
                                            </div>
                                                <span asp-validation-for="ReceiverName" class="text-danger small"></span>
                                        </div>

                                        <div class="mb-4">
                                                <label class="form-label fw-bold" asp-for="ReceiverPhone">聯絡電話</label>
                                            <div class="input-group shadow-sm">
                                                <span class="input-group-text bg-white border-end-0"><i class="fas fa-mobile-alt text-muted"></i></span>
                                                    <input asp-for="ReceiverPhone" type="tel" class="form-control border-start-0 ps-0 form-control-lg" placeholder="0912-345-678" required>
                                            </div>
                                        </div>

                                        <div class="mb-4">
                                            <label class="form-label fw-bold" asp-for="ReceiverEmail">電子郵件</label>
                                            <div class="input-group shadow-sm">
                                                <span class="input-group-text bg-white border-end-0"><i class="fas fa-mobile-alt text-muted"></i></span>
                                                <input asp-for="ReceiverEmail" type="tel" class="form-control border-start-0 ps-0 form-control-lg" placeholder="abc@def.com" required>
                                            </div>
                                        </div>

                                        <div class="mb-4">
                                            <label class="form-label fw-bold" asp-for="ReceiverAddress">送貨地址</label>
                                            <div class="input-group shadow-sm">
                                                <span class="input-group-text bg-white border-end-0"><i class="fas fa-map-marker-alt text-muted"></i></span>
                                                <input asp-for="ReceiverAddress" type="text" class="form-control border-start-0 ps-0 form-control-lg" placeholder="" required>
                                            </div>
                                        </div>

                                        <div class="mb-4">
                                            <label class="form-label fw-bold" for="OrderNote">備註</label>
                                            <textarea id="OrderNote" name="OrderNote" class="form-control shadow-sm" rows="3" placeholder="留言給烘焙甜點師"></textarea>
                                        </div>
                                        <input type="hidden" name="ShippingFee" :value="shippingFee" />
                                        <button type="submit" id="realSubmitBtn" class="d-none"></button>
                                    </form>
                                </div>

                                @* --- 右邊：訂單總結 --- *@
                                <div class="col-lg-5">
                                    <div class="card text-dark rounded-3 shadow-lg" style="background-color:#FFF9C4;" border: none;">
                                        <div class="card-body p-4">
                                            <div class="d-flex justify-content-between align-items-center mb-4">
                                                <h4 class="mb-0 fw-bold">訂單總結</h4>
                                                <i class="fas fa-shopping-basket fa-lg"></i>
                                            </div>

                                            <p class="small mb-3 fw-bold" style="color: rgba(0,0,0,0.6);">確認您的商品</p>

                                            <div class="mb-4 overflow-auto" style="max-height: 300px; border-bottom: 1px solid rgba(0,0,0,0.1);">
                                                @* 購物車資料 *@
                                                <div v-for="item in cart" :key="item.productId" class="d-flex align-items-center mb-3 pb-2">
                                                    <div class="flex-shrink-0">
                                                        <img :src="item.imgUrl" class="img-fluid rounded-2 shadow-sm"
                                                             style="width: 60px; height: 60px; object-fit: cover; background-color: #fff;">
                                                    </div>
                                                    <div class="flex-grow-1 ms-3">
                                                        <h6 class="mb-0 fw-bold" style="font-size: 0.9rem;">{{item.productName}}</h6>
                                                        <small style="color: rgba(0,0,0,0.5);">數量: {{item.quantity}}</small>
                                                    </div>
                                                    <div class="text-end">
                                                        <span class="fw-bold">${{formatNumber(item.price * item.quantity)}}</span>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="d-flex justify-content-between mb-2">
                                                <span>訂單小結</span>
                                                <span class="fw-bold">${{formatNumber(totalPrice)}}</span>
                                            </div>

                                            <div class="d-flex justify-content-between mb-4">
                                                <span>運費</span>
                                                <span class="fw-bold">${{shippingFee}}</span>
                                            </div>

                                            <hr class="my-4" style="border-top: 2px dashed rgba(0,0,0,0.15);">

                                            <div class="d-flex justify-content-between mb-4 fs-4 fw-bolder">
                                                <span>總額</span>
                                                <span>${{formatNumber(grandTotal)}}</span>
                                            </div>

                                            @* 確認下單按鈕 *@
                                            <a href="javascript:void(0);" onclick="document.getElementById('realSubmitBtn').click();"
                                               class="btn btn-block w-100 py-3 shadow fw-bold text-white btn-lg"
                                                   style="background-color: #FFC107; border-radius: 12px; font-size: 1.7rem; border: none;">
                                                結帳付款 <i class="fas fa-chevron-right ms-2"></i>
                                            </a>

                                            <div class="text-center mt-4">
                                                <small style="color: rgba(0,0,0,0.5);">
                                                    <i class="fas fa-shield-alt me-1"></i> 您的支付環境已受加密保護
                                                </small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

</body>

@section Scripts
{
    <script>
        const app = Vue.createApp({
            mixins:[CartMixin],
            data(){
                return {
                    shippingFee: @(ViewBag.ShippingFee ?? 60),
                    form: {
                        name: '',
                        phone: '',
                        email: '',
                        address: '',
                        note: ''
                    }
                }
            },
            computed: {
                grandTotal() {
                    return this.totalPrice + this.shippingFee;
                }
            },
            methods:{
                submitOrder() {
                    if (!this.form.name || !this.form.phone || !this.form.email || !this.form.address) {
                        alert('請填寫完整收件資訊');
                        return;
                    }
                    // 直接提交 HTML Form
                    document.getElementById('orderForm').submit();
                },
                formatNumber(num) {
                    if (!num) return '0';
                    return num.toLocaleString('zh-TW'); // 強制台灣格式
                }
            },
            mounted(){
                this.refreshCart();
            }
        }).mount('#checkoutPage');
    </script>

}
