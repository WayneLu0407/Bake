@using Bake.ViewModel
@model CheckoutViewModel

@{
    ViewData["Title"] = "Order Payment";
    string ReceiverName = ViewBag.ReceiverName ?? "N/A";
    string ReceiverPhone = ViewBag.ReceiverPhone ?? "N/A";
    string ReceiverAddress = ViewBag.ReceiverAddress ?? "N/A";
    string ReceiverEmail = ViewBag.ReceiverEmail ?? "N/A";
}

<section class="h-100 h-custom" style="background-color: #f8f9fa;">
    <div class="container py-5 h-100">
        <div class="row d-flex justify-content-center align-items-center h-100">
            <div class="col-lg-11 col-xl-10">
                <div class="card shadow-lg border-0" style="border-radius: 1.5rem; overflow: hidden;">

                    <div class="card-body p-0">
                        <div class="row g-0">

                            @* --- 左邊：確認資訊區 --- *@
                            <div class="col-lg-5 p-4 p-md-5" style="background-color: #fffbeb;">
                                <div class="d-flex align-items-center mb-4">
                                    <div class="icon-shape bg-warning text-white rounded-circle p-3 me-3 shadow-sm">
                                        <i class="fas fa-clipboard-check fa-lg"></i>
                                    </div>
                                    <h4 class="mb-0 fw-bold text-dark">訂單確認</h4>
                                </div>

                                <div class="card border-0 shadow-sm rounded-4 mb-4">
                                    <div class="card-body p-4">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <h6 class="fw-bold mb-0 text-dark"><i class="fas fa-map-marker-alt text-warning me-2"></i>送貨資訊明細</h6>
                                            <a asp-action="Info" class="text-muted small text-decoration-none">編輯</a>
                                        </div>
                                        <div class="mb-2">
                                            <small class="text-muted d-block">收件人</small>
                                            <span class="fw-bold">@ReceiverName</span>
                                        </div>
                                        <div class="mb-2">
                                            <small class="text-muted d-block">聯絡電話</small>
                                            <span class="fw-bold">@ReceiverPhone</span>
                                        </div>
                                        <div class="mb-2">
                                            <small class="text-muted d-block">電子信箱</small>
                                            <span class="fw-bold">@ReceiverEmail</span>
                                        </div>
                                        <div class="mb-0">
                                            <small class="text-muted d-block">地址</small>
                                            <span class="fw-bold" style="font-size: 0.9rem;">@ReceiverAddress</span>
                                        </div>
                                    </div>
                                </div>
                                <div id="paymentPage">
                                    <div class="mb-4">
                                        <h6 class="fw-bold mb-3 text-dark px-1">訂購商品</h6>
                                        <div class="overflow-auto pe-2" style="max-height: 200px;">
                                            @* 綁定 Vue 資料 *@
                                            <div v-for="item in cart" :key="item.productId" class="d-flex align-items-center mb-3">
                                                <img :src="item.imgUrl" class="rounded-3 shadow-sm" style="width: 50px; height: 50px; object-fit: cover; background-color: #fff;">
                                                <div class="ms-3 flex-grow-1">
                                                    <div class="small fw-bold text-dark text-truncate" style="max-width: 150px;">{{item.productName}}</div>
                                                    <div class="text-muted" style="font-size: 0.8rem;">數量: {{item.quantity}}</div>
                                                </div>
                                                <div class="text-end fw-bold small">${{formatNumber(item.price * item.quantity)}}</div>
                                            </div>
                                        </div>
                                    </div>

                                    <hr class="my-4 border-dashed">

                                    <div class="d-flex justify-content-between align-items-center px-1">
                                        <span class="text-dark fw-bold fs-5">訂單小計</span>
                                        <h5 class="fw-bolder text-dark mb-0">${{formatNumber(totalPrice)}}</h5>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center px-1">
                                        <span class="text-dark fw-bold fs-5">運費</span>
                                        <h5 class="mb-0">@ViewBag.ShippingFee</h5>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center px-1">
                                        <span class="text-dark fw-bold fs-3">訂單總額</span>
                                        <h3 class="fw-bolder text-dark mb-0">${{formatNumber(grandTotal)}}</h3>
                                    </div>
                                </div>
                                
                            </div>

                            @* --- 右邊：付款方式選擇 --- *@
                            <div class="col-lg-7 p-4 p-md-5 bg-white">
                                <h3 class="fw-bold text-dark mb-1">最後一步</h3>
                                <p class="text-muted mb-5">選擇您的付款方式並完成購買</p>

                                <form asp-controller="Checkout" asp-action="ConfirmPayment" method="post">
                                    <input type="hidden" name="ReceiverName" value="@ReceiverName" />
                                    <input type="hidden" name="ReceiverPhone" value="@ReceiverPhone" />
                                    <input type="hidden" name="ReceiverAddress" value="@ReceiverAddress" />
                                    <input type="hidden" name="ReceiverEmail" value="@ReceiverEmail" />
                                    @* --- 放藍星要的 --- *@
                                    <input type="hidden" name="MerchantID" value="@ViewData["MerchantID"]" />
                                    <input type="hidden" name="MerchantOrderNo" value="@ViewData["MerchantOrderNo"]"  />
                                    <input type="hidden" name="ItemDesc" value="@ViewData["ItemDesc"]"   />
                                    <input type="hidden" name="Amt" value="@ViewData["Amt"]"   />
                                    <input type="hidden" name="ExpireDate" value="@ViewData["ExpireDate"]"    />
                                    <input type="hidden" name="ReturnURL" value="@ViewData["ReturnURL"]" />
                                    <input type="hidden" name="ClientBackURL" value="@ViewData["ClientBackURL"]" />
                                    <input type="hidden" name="CustomerURL" value="@ViewData["CustomerURL"]" />
                                    <input type="hidden" name="NotifyURL" value="@ViewData["NotifyURL"]" />




                                    @* 信用卡選項 *@
                                    <div class="payment-option mb-3">
                                        <input class="d-none" type="radio" name="PaymentMethod" id="creditCard" value="0" checked>
                                        <label class="d-flex align-items-center p-4 rounded-4 border w-100 cursor-pointer shadow-sm active-payment" for="creditCard">
                                            <i class="far fa-credit-card fa-2x me-3 text-muted icon-main"></i>
                                            <div class="flex-grow-1">
                                                <div class="fw-bold text-dark">信用卡</div>
                                                <div class="small text-muted">Visa/Master/JCB 信用卡加密付款</div>
                                            </div>
                                            <i class="fas fa-check-circle fa-lg text-warning check-icon"></i>
                                        </label>
                                    </div>

                                    @* 轉帳 *@
                                    <div class="payment-option mb-3">
                                        <input class="d-none" type="radio" name="PaymentMethod" id="Transfer" value="1">
                                        <label class="d-flex align-items-center p-4 rounded-4 border w-100 cursor-pointer shadow-sm" for="Transfer">
                                            <i class="fas fa-university fa-2x me-3 text-muted icon-main"></i>
                                            <div class="flex-grow-1">
                                                <div class="fw-bold text-dark">轉帳</div>
                                                <div class="small text-muted">銀行轉帳</div>
                                            </div>
                                            <i class="fas fa-check-circle fa-lg text-warning check-icon d-none"></i>
                                        </label>
                                    </div>

                                    @* 貨到付款 *@
                                    <div class="payment-option mb-5">
                                        <input class="d-none" type="radio" name="PaymentMethod" id="PayWhenDelivered" value="2">
                                        <label class="d-flex align-items-center p-4 rounded-4 border w-100 cursor-pointer shadow-sm" for="PayWhenDelivered">
                                            <i class="fas fa-shipping-fast fa-2x me-3 text-muted icon-main"></i>
                                            <div class="flex-grow-1">
                                                <div class="fw-bold text-dark">貨到付款</div>
                                                <div class="small text-muted"></div>
                                            </div>
                                            <i class="fas fa-check-circle fa-lg text-warning check-icon d-none"></i>
                                        </label>
                                    </div>


                                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill shadow-lg fw-bold btn-lg"
                                            style="background-color: #1A237E; border: none; font-size: 1.2rem;">
                                        PLACE ORDER NOW <i class="fas fa-arrow-right ms-2"></i>
                                    </button>
                                </form>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .cursor-pointer {
        cursor: pointer;
    }

    .border-dashed {
        border-top: 2px dashed #ddd;
        opacity: 1;
    }

    /* 付款選項美化 */
    .payment-option label {
        transition: all 0.2s ease;
        border: 2px solid #eee !important;
    }

        .payment-option label:hover {
            background-color: #fffbeb;
            border-color: #ffc107 !important;
        }
    /* 選中狀態 */
    .payment-option input:checked + label {
        border-color: #ffc107 !important;
        background-color: #fff;
    }

        .payment-option input:checked + label .icon-main {
            color: #ffc107 !important;
        }

        .payment-option input:checked + label .check-icon {
            display: block !important;
        }

    /* 捲軸美化 */
    .overflow-auto::-webkit-scrollbar {
        width: 5px;
    }

    .overflow-auto::-webkit-scrollbar-thumb {
        background: #E0E0E0;
        border-radius: 10px;
    }
</style>

@section Scripts {
    <script>
        // 切換選中狀態的勾勾顯示
        document.querySelectorAll('input[name="PaymentMethod"]').forEach(input => {
            input.addEventListener('change', function() {
                document.querySelectorAll('.check-icon').forEach(icon => icon.classList.add('d-none'));
                if(this.checked) {
                    this.nextElementSibling.querySelector('.check-icon').classList.remove('d-none');
                }
            });
        });

        //購物清單
        const app = Vue.createApp({
            mixins:[CartMixin],
            data(){
                return {
                    shippingFee: @(ViewBag.ShippingFee ?? 60)
                }
            },
            computed: {
                grandTotal() {
                    return this.totalPrice + this.shippingFee;
                }
            },
            methods:{
                formatNumber(num) {
                    if (!num) return '0';
                    return num.toLocaleString('zh-TW'); //強制台灣格式
                }
            },
            mounted(){this.refreshCart();}
        }).mount('#paymentPage')
    </script>
}