@{
	Layout = "_Layout2";
}
<div class="row g-0 auth-row">
	<div class="col-lg-6">
		<div class="auth-cover-wrapper bg-primary-100">
			<div class="auth-cover">
				<div class="title text-center">
					<h1 class="text-primary mb-10"></h1>
					<p class="text-medium">
						註冊會員
						<br class="d-sm-block" />
						
					</p>
				</div>
				<div class="cover-image">
					<img src="~/seller_assets/images/auth/signup-image.svg" alt="" />
				</div>
				<div class="shape-image">
					<img src="assets/images/auth/shape.svg" alt="" />
				</div>
			</div>
		</div>
	</div>
	<div class="col-lg-6">
		<div class="signup-wrapper">
			<div class="form-wrapper">
				<h6 class="mb-15">填寫會員資料</h6>
				<form action="#" method="">
					<div class="row">
						<div class="col-12">
							<div class="input-style-1">
								<label>姓名</label>
								<input type="text" placeholder="Name" />
							</div>
						</div>
						<!-- end col -->
						<div class="col-12">
							<div class="input-style-1">
								<label>電子郵件</label>
								<input type="email" placeholder="Email" />
							</div>
						</div>
						<!-- end col -->
						<div class="col-12">
							<div class="input-style-1">
								<label>密碼</label>
								<input type="password" placeholder="Password" />
							</div>
						</div>
						<!-- end col -->
						<div class="col-12">
							<div class="form-check checkbox-style mb-30">
								<input class="form-check-input" type="checkbox" value="" id="checkbox-not-robot" />
								<label class="form-check-label" for="checkbox-not-robot">
									我不是機器人
								</label>
							</div>
						</div>
						<!-- end col -->
						<div class="col-12">
							<div class="button-group d-flex justify-content-center flex-wrap">
								<a class="main-btn primary-btn btn-hover w-100 text-center" asp-controller="Home" asp-action="Login">
									註冊
								</a>
							</div>
						</div>
					</div>
					<!-- end row -->
				</form>
			</div>
		</div>
	</div>
</div>