                                                <input type="text" class="form-control input-number" v-model.number="product.qty">
                                                <span class="input-group-btn">
                                                    <button type="button" class="quantity-right-plus btn btn-success btn-number" @@click.prevent="product.qty += 1">
                                                        <svg width="16" height="16"><use xlink:href="#plus"></use></svg>
                                                    </button>
                                                </span>
                                            </div>
                                                        <a href="#" class="btn btn-danger btn-sm w-20 mt-1" @@click.prevent="addCart(product)">加入購物車 <iconify-icon icon="uil:shopping-cart"></a>
                                        </div>
                                    </div>
                                </div>
                            <!-- / 單一商品 -->
                        </div>
                    </div>
                    <!-- / products-carousel -->
                </div>
            </div>
        </div>
    </section>

    <section class="py-5 overflow-hidden">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-12">

                    <div class="section-header d-flex flex-wrap justify-content-between my-5">

                        <h2 class="section-title">新商家推薦</h2>

                        @* <div class="d-flex align-items-center">
                            <a class="btn-link text-decoration-none" asp-area="" asp-controller="Products" asp-action="Index">查看更多</a>
                            <div class="swiper-buttons">
                                <button class="swiper-prev brand-carousel-prev btn btn-yellow">❮</button>
                                <button class="swiper-next brand-carousel-next btn btn-yellow">❯</button>
                            </div>
                        </div> *@
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">

                    <div class="brand-carousel swiper">
                        <div class="swiper-wrapper" >
                            <!-- 單一店家 — 複製此區塊重複使用 -->
                              <div class="swiper-slide" v-for="shop in shops" :key="shop.userId">
                                <div class="card mb-3 p-3 rounded-4 shadow border-0">
                                    <div class="row g-0">
                                        <div class="col-md-4">
                                           <img :src="shop.shopImg" class="img-fluid rounded" :alt="shop.shopName">
                                        </div>
                                        <div class="col-md-8">
                                            <div class="card-body py-0">
                                                <h5 class="card-title">{{ shop.shopName }}</h5>
                                                <p class="text-muted mb-0 shop-desc">{{ shop.shopDescription }}</p>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div> 
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts
{
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <script>
        const app=Vue.createApp({
            mixins: [CartMixin],
            data(){
                return{
                    products: [],
                    product:{},
                    sortBy: 'default',
                    shops:[],
                }
            },
            methods: {
                discountLabel(discount) {
                if (!discount || discount <= 0) return null
                return `-${Math.round(discount * 100)}%`   // 0.20 → "-20%"
                },
                originalPrice(price, discount) {
                if (!discount || discount <= 0) return null
                return Math.round(price / (1 - discount))  // 100 / 0.8 = 125
                }
            },
            computed:{

                 productsByRating(){
                 return [...this.products].sort((a,b)=> b.productRating - a.productRating)
                 },
                 productsByDate(){
                 return [...this.products].sort((a,b)=> new Date(b.productDate) - new Date(a.productDate))
                 },
                 productsByDiscount(){
                 return [...this.products].sort((a,b)=> b.productDiscount - a.productDiscount)
                 }

            },
            async mounted() {

                const res = await fetch('/api/Product/Get')
                const data = await res.json()
                this.products = data.map(p => ({ ...p, qty: 1 }))
                const sho = await fetch('/api/Shop/Get')
                this.shops = await sho.json()

                this.$nextTick(() => {
                // 新品上市 — 銷毀再重建
                const el1 = document.querySelector('.products-carousel')
                if (el1 && el1.swiper) {
                el1.swiper.destroy(true, true)
                }
                new Swiper('.products-carousel', {
                loop: false,
                spaceBetween: 30,
                speed: 500,
                navigation: {
                nextEl: '.products-carousel-next',
                prevEl: '.products-carousel-prev',
                },
                breakpoints: {
                0:    { slidesPerView: 2 },
                768:  { slidesPerView: 3 },
                991:  { slidesPerView: 4 },
                1200: { slidesPerView: 5 },
                }
                })

                // 推薦商品 — 銷毀再重建
                const el2 = document.querySelector('.products-carousel2')
                if (el2 && el2.swiper) {
                el2.swiper.destroy(true, true)
                }
                new Swiper('.products-carousel2', {
                loop: false,
                spaceBetween: 30,
                speed: 500,
                navigation: {
                nextEl: '.products-carousel2-next',
                prevEl: '.products-carousel2-prev',
                },
                breakpoints: {
                0:    { slidesPerView: 2 },
                768:  { slidesPerView: 3 },
                991:  { slidesPerView: 4 },
                1200: { slidesPerView: 5 },
                }
                })
                const el3 = document.querySelector('.brand-carousel')
                if (el3 && el3.swiper) {
                el3.swiper.destroy(true, true)
                }
                new Swiper('.brand-carousel', {
                loop: false,
                spaceBetween: 20,
                speed: 500,
                navigation: {
                nextEl: '.brand-carousel-next',
                prevEl: '.brand-carousel-prev',
                },
                breakpoints: {
                0:    { slidesPerView: 1 },
                768:  { slidesPerView: 2 },
                991:  { slidesPerView: 3 },
                1200: { slidesPerView: 4 },
                }
                })
               })
            }
        });
        app.mount('#product');
    </script>

}