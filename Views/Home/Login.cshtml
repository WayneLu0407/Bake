@model Bake.Models.LoginModel
@{
	Layout = null;
	ViewBag.Title = "會員登入";
}

<head>
	<title>@ViewData["Title"] 會員登入</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
	<link href="~/css/login.min.css" rel="stylesheet" />
	<link href="~/seller_assets/css/sweetstack-admin-override.css" rel="stylesheet" />
	
</head>
<body>
	<div class="login-container">
		<div class="login-card">
			<div class="login-header">
				<h2>登入</h2>
				<p>輸入您的Email和密碼</p>
			</div>

			<form asp-controller="Home" asp-action="Login" method="post" class="login-form" id="loginForm" novalidate>
				<div class="form-group">
					<label>Email</label>
					<div class="input-wrapper">
						
						<input type="email" id="email" name="account" required autocomplete="email" ">
						<span asp-validation-for="Account" class="text-danger" ></span>
					</div>
					
				</div>

				<div class="form-group">
					<label>密碼</label>
					<div class="input-wrapper password-wrapper">
						
						<input type="password" id="password" name="password" required autocomplete="current-password">
						<span asp-validation-for="Password" class="text-danger"></span>
						<button type="button" class="password-toggle" id="passwordToggle" aria-label="Toggle password visibility">
							<span class="eye-icon"></span>
						</button>
					</div>
					
				</div>

				<div class="form-options">
					<label class="remember-wrapper">
						<input type="checkbox" id="remember" name="remember">
						<span class="checkbox-label">
							<span class="checkmark"></span>
							記住我
						</span>
					</label>

					<a class="forgot-password" asp-controller="Home" asp-action="Forgot_password">忘記密碼?</a>
				</div>

				<button type="submit" class="login-btn" >
					<span class="btn-text">登入</span>
					<span class="btn-loader"></span>
				</button>
				<a class="text-decoration-none" asp-controller="Home" asp-action="Register">註冊帳號</a>
			</form>
		</div>
	</div>
</body>



@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
}
